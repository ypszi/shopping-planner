#!/usr/bin/env php
<?php

declare(strict_types=1);

use PeterPecosz\ShoppingPlanner\Command\YamlFormatter;

$projectRoot = __DIR__ . '/..';

require $projectRoot . '/vendor/autoload.php';

$yamlPath = $argv[1] ?? null;

if (empty($yamlPath)) {
    echo "Yaml file name or path is required.", PHP_EOL;
    exit(1);
}

if (is_file($yamlPath = $projectRoot . '/'. $yamlPath)) {
    $yamlPath = realpath($yamlPath);

    (new YamlFormatter())->format($yamlPath);

    exit (0);
}

if (is_file($yamlPath = $projectRoot . '/app/' . $yamlPath . '.yaml')) {
    $yamlPath = realpath($yamlPath);

    (new YamlFormatter())->format($yamlPath);
}

exit (0);
